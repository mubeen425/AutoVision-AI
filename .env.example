# Place this file at the repository root (next to frontend/ and backend/).
# backend/main.py and Vite (frontend) both load from here.

# Python API (backend/main.py). Either name can hold your primary key:
GEMINI_API_KEY=
# VITE_GEMINI_API_KEY=

# Extra keys on Render (optional). After primary key(s), order is:
# GEMINI_API_KEY_2 → GEMINI_API_KEY_3 → GEMINI_API_KEY_4 → GEMINI_API_KEY_5
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# Alternative: comma-separated list (optional)
# GEMINI_API_KEYS=key1,key2,key3

# Model (optional). Backend uses GEMINI_MODEL, or VITE_GEMINI_MODEL, else gemini-2.5-flash.
# Set on Render to override: e.g. GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
# Comma-separated fallbacks (try order after primary):
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Production: frontend — optional; build defaults to Render API if unset (see geminiService.js)
# VITE_API_BASE_URL=https://autovision-ai-axox.onrender.com

# Production: backend — extra origins (e.g. custom domain). *.vercel.app is allowed in code.
# ALLOW_ORIGINS=https://www.your-custom-domain.com
