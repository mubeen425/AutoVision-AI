{
  "name": "wowcar-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo root — run scripts from here or from frontend/ and backend/",
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "api": "python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000",
    "api:win": ".venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000"
  }
}
